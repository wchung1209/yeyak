# ── Supabase ───────────────────────────────────────────────
# Same URL as the web app, but the worker only uses the service role key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Apify ──────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_...
APIFY_RESY_ACTOR_ID=clearpath/resy-booker

# ── Redis ──────────────────────────────────────────────────
# Provided by the Railway Redis plugin.
REDIS_URL=redis://default:password@host:6379

# ── Resend + Twilio (same values as web) ───────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reservationist@yourdomain.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
